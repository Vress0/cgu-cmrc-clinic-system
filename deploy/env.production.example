# Copy this file to .env.production and replace every generated secret.
#
# The install scripts generate secure defaults automatically. Edit this file only
# when you need a manual production configuration.

COMPOSE_PROJECT_NAME=cgu_cmrc_clinic
POSTGRES_VOLUME_NAME=clinic_postgres_data
UPLOADS_VOLUME_NAME=clinic_uploads
BACKUPS_VOLUME_NAME=clinic_backups
APP_ENV=production
APP_NAME=CGU CMRC Clinic System
PUBLIC_BASE_URL=http://localhost

POSTGRES_DB=clinic_system
POSTGRES_USER=clinic_system
POSTGRES_PASSWORD=change-this-postgres-password

DATABASE_URL=postgresql+psycopg://clinic_system:change-this-postgres-password@postgres:5432/clinic_system
DATABASE_CONNECT_TIMEOUT_SECONDS=5

SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_FULL_NAME=System Administrator
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
ENABLE_DEMO_MODE=true
DEFAULT_DATA_MODE=LIVE
ALLOW_DEMO_RESET=true

BACKEND_CORS_ORIGINS=http://localhost
NEXT_PUBLIC_API_BASE_URL=http://localhost/api/v1
INTERNAL_API_BASE_URL=http://backend:8000/api/v1

HTTP_PORT=80
HTTPS_PORT=443
