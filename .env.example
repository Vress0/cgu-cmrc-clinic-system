COMPOSE_PROJECT_NAME=cgu_cmrc_clinic

POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinic
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://clinic:clinic@postgres:5432/clinic
DATABASE_CONNECT_TIMEOUT_SECONDS=3
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
SECRET_KEY=change-this-development-secret-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
INTERNAL_API_BASE_URL=http://backend:8000/api/v1
